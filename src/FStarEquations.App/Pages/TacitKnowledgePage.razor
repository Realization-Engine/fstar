@page "/tacit-knowledge"

<PageTitle>Tacit Knowledge — Eq (12), (12a), (12b), (13)</PageTitle>

<h1>Tacit Knowledge — Eq (12), (12a), (12b), (13)</h1>

<blockquote>
    Tacit knowledge — the kind that cannot be written down — transmits only through shared work between senior and junior practitioners. As the multiplier automates away shared work, the transmission channel narrows. Once broken, the pipeline cannot be restarted by hiring alone.
</blockquote>

@* ─── Shared Work Decay — Eq (12b) ─── *@
<ChartCard Title="Shared Work Decay — Eq (12b)"
           Description="W = W₀ · e^(−ψ·M) as multiplier M varies.">
    <ChildContent>
        <LineChart Series="@_sharedWorkSeries"
                   XLabel="Multiplier (M)"
                   YLabel="Shared Work (W)"
                   XMin="0.5" XMax="5"
                   YMin="0"
                   ShowGrid="true" />
    </ChildContent>
    <TheoryContent>
        <h4>Equation</h4>
        <KatexBlock Latex="W(t) = W_0 \cdot e^{-\psi \cdot M} \qquad (12b)" />
        <h4>In Plain Language</h4>
        <p>Shared work between seniors and juniors declines exponentially with the multiplier's power. The first increments of M eliminate the most delegable tasks — high-volume, well-specified work that was the traditional vehicle for junior learning — with diminishing returns thereafter. W(t) approaches zero asymptotically (shrinking ever closer to zero but never fully reaching it).</p>
        <h4>Connections</h4>
        <ul>
            <li>Knowledge stock Eq (12)</li>
            <li>Transmission Eq (12a)</li>
            <li>Pipeline break Eq (13)</li>
        </ul>
    </TheoryContent>
</ChartCard>

@* ─── Knowledge Pipeline — Eq (12), (12a), (13) ─── *@
<ChartCard Title="Knowledge Pipeline — Eq (12), (12a), (13)"
           Description="Forward-Euler integration of K(t) with transmission and decay threshold.">
    <ChildContent>
        <LineChart Series="@_pipelineSeries"
                   XLabel="Time (years)"
                   YLabel="Knowledge / Transmission"
                   XMin="0" XMax="20"
                   ShowGrid="true"
                   Width="600" Height="400" />
        <ThresholdIndicator Label="@(_pipelineBroken ? "Pipeline BROKEN (T < δ·K)" : "Pipeline intact (T ≥ δ·K)")"
                            Passed="@(!_pipelineBroken)" />
    </ChildContent>
    <TheoryContent>
        <h4>Equations</h4>
        <KatexBlock Latex="K_{\text{tacit}}(t+1) = K_{\text{tacit}}(t) \times (1 - \delta) + T(t) \qquad (12)" />
        <KatexBlock Latex="T(t) = \phi \times W(t) \times F_{\text{senior}}(t) \qquad (12a)" />
        <KatexBlock Latex="T(t) < \delta \cdot K_{\text{tacit}}(t) \implies K_{\text{tacit}} \to 0 \qquad (13)" />
        <h4>In Plain Language</h4>
        <p>The stock of tacit knowledge next year equals what survives attrition (K reduced by δ from retirements/turnover) plus whatever gets transmitted from seniors to juniors (T). Transmission depends on three things multiplied together: a coupling constant (φ), shared work volume (W), and senior force (F_senior). If any approaches zero, transmission stops. There is a critical threshold where decay exceeds transmission — once crossed, the tacit knowledge stock enters irreversible decline. You won't notice it's broken for years.</p>
        <h4>Connections</h4>
        <ul>
            <li>Shared work decay Eq (12b)</li>
            <li>Senior force atrophy Eq (11)</li>
            <li>Cohort discontinuity Eq (32)</li>
            <li>Transfer ceiling Eq (27)</li>
        </ul>
    </TheoryContent>
</ChartCard>

<FloatingSliderPanel Visible="true" Title="Tacit Knowledge Parameters" DefaultY="100">
    <div class="slider-group-header">Eq (12b): Shared Work Decay</div>
    <ParameterSlider Label="W₀ (initial shared work)" Min="0" Max="10" Step="0.5"
                     Value="@_w0"
                     ValueChanged="@OnW0Changed" />
    <ParameterSlider Label="ψ (decay rate)" Min="0.01" Max="1" Step="0.01"
                     Value="@_psi"
                     ValueChanged="@OnPsiChanged" />
    <div class="slider-group-header">Eq (12), (12a), (13): Knowledge Pipeline</div>
    <ParameterSlider Label="δ (depreciation)" Min="0.01" Max="0.5" Step="0.01"
                     Value="@_pipeDelta"
                     ValueChanged="@OnPipeDeltaChanged" />
    <ParameterSlider Label="φ (transmission coeff)" Min="0.1" Max="2" Step="0.01"
                     Value="@_pipePhi"
                     ValueChanged="@OnPipePhiChanged" />
    <ParameterSlider Label="W₀ (pipeline shared work)" Min="0" Max="10" Step="0.5"
                     Value="@_pipeW0"
                     ValueChanged="@OnPipeW0Changed" />
    <ParameterSlider Label="ψ (pipeline decay rate)" Min="0.01" Max="1" Step="0.01"
                     Value="@_pipePsi"
                     ValueChanged="@OnPipePsiChanged" />
    <ParameterSlider Label="M (multiplier)" Min="0.5" Max="5" Step="0.1"
                     Value="@_pipeM"
                     ValueChanged="@OnPipeMChanged" />
    <ParameterSlider Label="F_senior (senior force)" Min="0" Max="10" Step="0.1"
                     Value="@_pipeForceSenior"
                     ValueChanged="@OnPipeForceSeniorChanged" />
    <ParameterSlider Label="K₀ (initial knowledge)" Min="0" Max="20" Step="0.5"
                     Value="@_pipeK0"
                     ValueChanged="@OnPipeK0Changed" />
</FloatingSliderPanel>

@code {
    private double _w0 = 5.0;
    private double _psi = 0.2;

    private IReadOnlyList<ChartSeries> _sharedWorkSeries = Array.Empty<ChartSeries>();

    // Knowledge Pipeline params
    private double _pipeDelta = 0.1;
    private double _pipePhi = 0.5;
    private double _pipeW0 = 5.0;
    private double _pipePsi = 0.2;
    private double _pipeM = 1.0;
    private double _pipeForceSenior = 5.0;
    private double _pipeK0 = 10.0;

    private IReadOnlyList<ChartSeries> _pipelineSeries = Array.Empty<ChartSeries>();
    private bool _pipelineBroken;

    protected override void OnInitialized()
    {
        RecalcSharedWork();
        RecalcPipeline();
    }

    private void RecalcSharedWork()
    {
        var points = new List<DataPoint>();
        for (double m = 0.5; m <= 5.0; m += 0.05)
        {
            points.Add(new DataPoint(m, TacitKnowledge.SharedWork(_w0, _psi, m)));
        }

        _sharedWorkSeries = new List<ChartSeries>
        {
            new("Shared Work — Eq (12b)", points, "#2563eb", 2.0)
        };
    }

    private void RecalcPipeline()
    {
        double delta = _pipeDelta, phi = _pipePhi, w0 = _pipeW0, psi = _pipePsi;
        double m = _pipeM, fSenior = _pipeForceSenior, k0 = _pipeK0;

        double sharedWork = TacitKnowledge.SharedWork(w0, psi, m);
        double transmission = TacitKnowledge.Transmission(phi, sharedWork, fSenior);

        // Integrate dK/dt = transmission - delta * K
        var kValues = Integration.ForwardEuler(k0, 0, 20, 0.1, (t, k) => transmission - delta * k);

        int steps = kValues.Length;
        var kPts = new List<DataPoint>(steps);
        var tPts = new List<DataPoint>(steps);
        var threshPts = new List<DataPoint>(steps);

        for (int i = 0; i < steps; i++)
        {
            double time = i * 0.1;
            kPts.Add(new DataPoint(time, kValues[i]));
            tPts.Add(new DataPoint(time, transmission));
            threshPts.Add(new DataPoint(time, delta * kValues[i]));
        }

        _pipelineSeries = new List<ChartSeries>
        {
            new("K_tacit(t)", kPts, "#2563eb", 2.0),
            new("Transmission (T)", tPts, "#16a34a", 1.5),
            new("δ·K threshold", threshPts, "#dc2626", 1.5)
        };

        // Check pipeline status at final time step
        double kFinal = kValues[^1];
        _pipelineBroken = TacitKnowledge.IsPipelineBroken(transmission, delta, kFinal);
    }

    private void OnW0Changed(double val) { _w0 = val; RecalcSharedWork(); }
    private void OnPsiChanged(double val) { _psi = val; RecalcSharedWork(); }

    // Pipeline slider handlers
    private void OnPipeDeltaChanged(double val) { _pipeDelta = val; RecalcPipeline(); }
    private void OnPipePhiChanged(double val) { _pipePhi = val; RecalcPipeline(); }
    private void OnPipeW0Changed(double val) { _pipeW0 = val; RecalcPipeline(); }
    private void OnPipePsiChanged(double val) { _pipePsi = val; RecalcPipeline(); }
    private void OnPipeMChanged(double val) { _pipeM = val; RecalcPipeline(); }
    private void OnPipeForceSeniorChanged(double val) { _pipeForceSenior = val; RecalcPipeline(); }
    private void OnPipeK0Changed(double val) { _pipeK0 = val; RecalcPipeline(); }
}
