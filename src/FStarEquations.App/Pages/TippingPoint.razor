<FloatingSliderPanel Visible="true" Title="Tipping Point Parameters" DefaultY="100">
    <div class="slider-group-header">Eq (14): Tipping Point F*</div>
    <ParameterSlider Label="β (decay)" Min="0.01" Max="1" Step="0.01" Value="@_beta" ValueChanged="OnBetaChanged" />
    <ParameterSlider Label="R (replacement)" Min="0" Max="5" Step="0.1" Value="@_replacement" ValueChanged="OnReplacementChanged" />
    <ParameterSlider Label="σ (absorption rate)" Min="0" Max="2" Step="0.1" Value="@_sigma" ValueChanged="OnSigmaChanged" />
    <ParameterSlider Label="M_abs (absorbed)" Min="0" Max="5" Step="0.1" Value="@_mAbsorbed" ValueChanged="OnMAbsorbedChanged" />
    <ParameterSlider Label="γ (engagement rate)" Min="0.01" Max="1" Step="0.01" Value="@_gamma" ValueChanged="OnGammaChanged" />
    <ParameterSlider Label="E (engagement)" Min="0.1" Max="5" Step="0.1" Value="@_engagement" ValueChanged="OnEngagementChanged" />
    <div class="slider-group-header">Eq (11): Force Dynamics</div>
    <ParameterSlider Label="α (struggle coeff)" Min="0" Max="1" Step="0.01" Value="@Alpha" ValueChanged="OnAlphaChanged" />
    <ParameterSlider Label="S (struggle)" Min="0" Max="5" Step="0.1" Value="@Struggle" ValueChanged="OnStruggleChanged" />
</FloatingSliderPanel>

@code {
    // Shared slider parameters
    private double _beta = 0.3;
    private double _replacement = 2.0;
    private double _sigma = 0.5;
    private double _mAbsorbed = 1.0;
    private double _gamma = 0.2;
    private double _engagement = 1.0;
    private double _alpha = 0.5;
    private double _struggle = 2.0;

    // Properties for two-way slider binding
    private double Beta { get => _beta; set => _beta = value; }
    private double Replacement { get => _replacement; set => _replacement = value; }
    private double Sigma { get => _sigma; set => _sigma = value; }
    private double MAbsorbed { get => _mAbsorbed; set => _mAbsorbed = value; }
    private double Gamma { get => _gamma; set => _gamma = value; }
    private double Engagement { get => _engagement; set => _engagement = value; }
    private double Alpha { get => _alpha; set => _alpha = value; }
    private double Struggle { get => _struggle; set => _struggle = value; }

    // Computed values
    private double FStarValue => ForceDynamics.TippingPoint(Beta, Replacement, Sigma, MAbsorbed, Gamma, Engagement);
    private double NumberLineMax => Math.Max(FStarValue * 2, 10);

    // 1. Population points distributed around a configurable mean
    private IReadOnlyList<NumberLinePoint> PopulationPoints => GeneratePopulationPoints();

    // 2. Tornado factors
    private IReadOnlyList<TornadoFactor> TornadoFactors => new List<TornadoFactor>
    {
        new("β × R (decay)", Beta * Replacement, 0),
        new("σ × M_abs (absorption)", Sigma * MAbsorbed, 0),
        new("γ × E (engagement)", 0, -(Gamma * Engagement))
    };

    // 3. Phase curve
    private IReadOnlyList<DataPoint> PhaseCurve => GeneratePhaseCurve();

    // 4. Hysteresis
    private double DfDtDecay => ForceDynamics.DfDt(Alpha, Struggle, Gamma, Engagement, FStarValue - 1, Beta, Replacement, Sigma, MAbsorbed);
    private double DfDtRecovery => ForceDynamics.DfDt(Alpha, Struggle, Gamma, Engagement, FStarValue + 1, Beta, Replacement, Sigma, MAbsorbed);
    private bool HysteresisPresent => ForceDynamics.IsHysteresisPresent(DfDtDecay, DfDtRecovery);
    private double HysteresisMin => Math.Min(DfDtDecay, DfDtRecovery) * 1.2;
    private double HysteresisMax => Math.Max(DfDtDecay, DfDtRecovery) * 1.2;

    private IReadOnlyList<NumberLinePoint> HysteresisPoints => new List<NumberLinePoint>
    {
        new(DfDtDecay, "#dc2626"),
        new(DfDtRecovery, "#2563eb")
    };

    private List<NumberLinePoint> GeneratePopulationPoints()
    {
        var points = new List<NumberLinePoint>();
        var mean = FStarValue * 0.8;
        var spread = FStarValue * 0.4;
        if (spread < 0.5) spread = 0.5;

        for (int i = 0; i < 20; i++)
        {
            var value = mean + (i - 10) * spread / 10.0;
            var color = value < FStarValue ? "#2563eb" : "#dc2626";
            points.Add(new NumberLinePoint(value, color));
        }
        return points;
    }

    private List<DataPoint> GeneratePhaseCurve()
    {
        var curve = new List<DataPoint>();
        for (double f = 0; f <= 10; f += 0.1)
        {
            var dfdt = ForceDynamics.DfDt(Alpha, Struggle, Gamma, Engagement, f, Beta, Replacement, Sigma, MAbsorbed);
            curve.Add(new DataPoint(f, dfdt));
        }
        return curve;
    }

    // Slider callbacks
    private void OnBetaChanged(double v) => Beta = v;
    private void OnReplacementChanged(double v) => Replacement = v;
    private void OnSigmaChanged(double v) => Sigma = v;
    private void OnMAbsorbedChanged(double v) => MAbsorbed = v;
    private void OnGammaChanged(double v) => Gamma = v;
    private void OnEngagementChanged(double v) => Engagement = v;
    private void OnAlphaChanged(double v) => Alpha = v;
    private void OnStruggleChanged(double v) => Struggle = v;
}
