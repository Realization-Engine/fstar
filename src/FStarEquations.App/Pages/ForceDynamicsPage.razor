            })
        };
    }

    private void RecalcSensitivity()
    {
        // Build three series: one for each layer, all vs R
        var surfPts = new List<DataPoint>();
        var midPts = new List<DataPoint>();
        var deepPts = new List<DataPoint>();
        for (double r = 0; r <= 5.0; r += 0.1)
        {
            surfPts.Add(new DataPoint(r, ForceDynamics.DfSurfaceDt(_betaSurface, r)));
            midPts.Add(new DataPoint(r, ForceDynamics.DfMiddleDt(_alphaM, _struggle, _gammaM, _engagement, _forceMid, _betaM, r)));
            deepPts.Add(new DataPoint(r, ForceDynamics.DfDeepDt(_alphaD, _struggle, _betaD, r)));
        }

        _sensitivitySeries = new List<ChartSeries>
        {
            new("Surface (11a)", surfPts, "#2563eb", 2.0),
            new("Middle (11b)", midPts, "#16a34a", 2.0),
            new("Deep (11c)", deepPts, "#dc2626", 2.0)
        };

        _sensitivityHighlight = new HashSet<int> { 0, 1, 2 };

        double surfY = ForceDynamics.DfSurfaceDt(_betaSurface, _odeReplacement);
        double midY = ForceDynamics.DfMiddleDt(_alphaM, _struggle, _gammaM, _engagement, _forceMid, _betaM, _odeReplacement);
        double deepY = ForceDynamics.DfDeepDt(_alphaD, _struggle, _betaD, _odeReplacement);

        _sensitivityMarkers = new List<ChartMarker>
        {
            new(_odeReplacement, surfY, "#2563eb", Tooltip: new List<string>
            {
                "Surface Layer",
                $"R = {_odeReplacement:F1}, dF/dt = {surfY:F2}",
                "Fastest decay, fully substituted by LLM"
            }),
            new(_odeReplacement, midY, "#16a34a", Tooltip: new List<string>
            {
                "Middle Layer",
                $"R = {_odeReplacement:F1}, dF/dt = {midY:F2}",
                "Critical: tipping point operates here"
            }),
            new(_odeReplacement, deepY, "#dc2626", Tooltip: new List<string>
            {
                "Deep Layer",
                $"R = {_odeReplacement:F1}, dF/dt = {deepY:F2}",
                "Most resilient, hardest to rebuild"
            })
        };
    }

    private void RecalcOde()
    {
        var y0 = new double[] { 5.0, 3.0, 4.0, 6.0 }; // F_total, f_surface, f_middle, f_deep

        double alpha = _odeAlpha, beta = _odeBeta, gamma = _odeGamma, sigma = _odeSigma;
        double eng = _odeEngagement, str = _odeStruggle, rep = _odeReplacement, mAbs = _odeMAbsorbed;
        double dt = _odeDt;

        var result = Integration.ForwardEulerSystem(y0, 0, 20, dt, (t, y) => new double[]
        {
            ForceDynamics.DfDt(alpha, str, gamma, eng, y[0], beta, rep, sigma, mAbs),
            ForceDynamics.DfSurfaceDt(beta, rep),
            ForceDynamics.DfMiddleDt(alpha, str, gamma, eng, y[2], beta, rep),
            ForceDynamics.DfDeepDt(alpha, str, beta, rep)
        });

        int steps = result[0].Length;
        var totalPts = new List<DataPoint>(steps);
        var surfPts = new List<DataPoint>(steps);
        var midPts = new List<DataPoint>(steps);
        var deepPts = new List<DataPoint>(steps);
        var tippingPts = new List<DataPoint>(steps);

        double fStar = (eng > 0 && gamma > 0)
            ? ForceDynamics.TippingPoint(beta, rep, sigma, mAbs, gamma, eng)
            : double.NaN;
        _tippingPointValue = double.IsNaN(fStar) || double.IsInfinity(fStar) ? 0 : fStar;

        // Hysteresis check: compare decay rate (below F*) vs recovery rate (above F*)
        double dfDtAtDecay = ForceDynamics.DfDt(alpha, str, gamma, eng,
            Math.Max(0, _tippingPointValue - 1), beta, rep, sigma, mAbs);
        double dfDtAtRecovery = ForceDynamics.DfDt(alpha, str, gamma, eng,
            _tippingPointValue + 1, beta, rep, sigma, mAbs);
        _isHysteresisPresent = ForceDynamics.IsHysteresisPresent(dfDtAtDecay, dfDtAtRecovery);

        for (int i = 0; i < steps; i++)
        {
            double time = i * dt;
            totalPts.Add(new DataPoint(time, result[0][i]));
            surfPts.Add(new DataPoint(time, result[1][i]));
            midPts.Add(new DataPoint(time, result[2][i]));
            deepPts.Add(new DataPoint(time, result[3][i]));
            if (!double.IsNaN(fStar) && !double.IsInfinity(fStar))
            {
                tippingPts.Add(new DataPoint(time, fStar));
            }
        }

        var series = new List<ChartSeries>
        {
            new("F_total", totalPts, "#2563eb", 2.0),
            new("f_surface", surfPts, "#f97316", 2.0),
            new("f_middle", midPts, "#16a34a", 2.0),
            new("f_deep", deepPts, "#dc2626", 2.0)
        };

        if (tippingPts.Count > 0)
        {
            series.Add(new("F* (Tipping Point)", tippingPts, "#a855f7", 1.5));
        }

        _odeSeries = series;

        // Radar chart: ODE parameters
        _radarAxes = new List<RadarAxis>
        {
            new("α", _odeAlpha, 1.0, new List<string>
            {
                "Struggle coefficient (α)",
                $"Value: {_odeAlpha:F2} / 1.0 ({(_odeAlpha * 100):F0}%)",
                "Force gained from traditional struggle"
            }),
            new("β", _odeBeta, 1.0, new List<string>
            {
                "Decay coefficient (β)",
                $"Value: {_odeBeta:F2} / 1.0 ({(_odeBeta * 100):F0}%)",
                "Force lost to passive reliance"
            }),
            new("γ", _odeGamma, 1.0, new List<string>
            {
                "Engagement coefficient (γ)",
                $"Value: {_odeGamma:F2} / 1.0 ({(_odeGamma * 100):F0}%)",
                "Deliberate LLM-assisted growth"
            }),
            new("σ", _odeSigma, 2.0, new List<string>
            {
                "Absorbed coefficient (σ)",
                $"Value: {_odeSigma:F2} / 2.0 ({(_odeSigma / 2.0 * 100):F0}%)",
                "Organizational de-investment rate"
            }),
            new("E", _odeEngagement, 5.0, new List<string>
            {
                "Engagement (E)",
                $"Value: {_odeEngagement:F1} / 5.0 ({(_odeEngagement / 5.0 * 100):F0}%)",
                "Deliberate LLM use intensity"
            }),
            new("S", _odeStruggle, 5.0, new List<string>
            {
                "Struggle (S)",
                $"Value: {_odeStruggle:F1} / 5.0 ({(_odeStruggle / 5.0 * 100):F0}%)",
                "Productive struggle intensity"
            }),
            new("R", _odeReplacement, 5.0, new List<string>
            {
                "Replacement (R)",
                $"Value: {_odeReplacement:F1} / 5.0 ({(_odeReplacement / 5.0 * 100):F0}%)",
                "Passive reliance level"
            }),
            new("M_abs", _odeMAbsorbed, 5.0, new List<string>
            {
                "Absorbed capability (M_abs)",
                $"Value: {_odeMAbsorbed:F1} / 5.0 ({(_odeMAbsorbed / 5.0 * 100):F0}%)",
                "Model capability from F->M transfer"
            })
        };
    }

    // ─── Slider handlers ───

    private void OnBetaSurfaceChanged(double val) { _betaSurface = val; RecalcSurface(); RecalcSensitivity(); }
    private void OnAlphaMChanged(double val) { _alphaM = val; RecalcMiddle(); RecalcSensitivity(); }
    private void OnStruggleChanged(double val) { _struggle = val; RecalcMiddle(); RecalcDeep(); RecalcSensitivity(); }
    private void OnGammaMChanged(double val) { _gammaM = val; RecalcMiddle(); RecalcSensitivity(); }
    private void OnEngagementChanged(double val) { _engagement = val; RecalcMiddle(); RecalcSensitivity(); }
    private void OnForceMidChanged(double val) { _forceMid = val; RecalcMiddle(); RecalcSensitivity(); }
    private void OnBetaMChanged(double val) { _betaM = val; RecalcMiddle(); RecalcSensitivity(); }
    private void OnAlphaDChanged(double val) { _alphaD = val; RecalcDeep(); RecalcSensitivity(); }
    private void OnBetaDChanged(double val) { _betaD = val; RecalcDeep(); RecalcSensitivity(); }

    // ODE Simulator slider handlers
    private void OnOdeAlphaChanged(double val) { _odeAlpha = val; RecalcOde(); }
    private void OnOdeBetaChanged(double val) { _odeBeta = val; RecalcOde(); }
    private void OnOdeGammaChanged(double val) { _odeGamma = val; RecalcOde(); }
    private void OnOdeSigmaChanged(double val) { _odeSigma = val; RecalcOde(); }
    private void OnOdeEngagementChanged(double val) { _odeEngagement = val; RecalcOde(); }
    private void OnOdeStruggleChanged(double val) { _odeStruggle = val; RecalcOde(); }
    private void OnOdeReplacementChanged(double val)
    {
        _odeReplacement = val;
        RecalcSurface(); RecalcMiddle(); RecalcDeep(); RecalcSensitivity(); RecalcOde();
    }
    private void OnOdeMAbsorbedChanged(double val) { _odeMAbsorbed = val; RecalcOde(); }
    private void OnOdeDtChanged(double val) { _odeDt = val; RecalcOde(); }
}
