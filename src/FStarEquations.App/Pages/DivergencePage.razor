    // ─── Sensitivity Analysis ───
    private void RecalcSensitivity()
    {
        // Sweep each parameter from its min to max, compute final gap
        var paramDefs = new (string Name, double Min, double Max, double Current, string Color, Func<double, double> GapAt)[]
        {
            ("\u03b1", 0.0, 1.0, _divAlpha, "#10b981",
                v => ComputeFinalGap(v, _divStruggle0, _divGamma, _divM, _divBeta, _divKappa)),
            ("S\u2080", 0.0, 5.0, _divStruggle0, "#f59e0b",
                v => ComputeFinalGap(_divAlpha, v, _divGamma, _divM, _divBeta, _divKappa)),
            ("\u03b3", 0.0, 1.0, _divGamma, "#2563eb",
                v => ComputeFinalGap(_divAlpha, _divStruggle0, v, _divM, _divBeta, _divKappa)),
            ("M", 0.5, 5.0, _divM, "#dc2626",
                v => ComputeFinalGap(_divAlpha, _divStruggle0, _divGamma, v, _divBeta, _divKappa)),
            ("\u03b2", 0.0, 1.0, _divBeta, "#9333ea",
                v => ComputeFinalGap(_divAlpha, _divStruggle0, _divGamma, _divM, v, _divKappa)),
            ("\u03ba", 0.0, 2.0, _divKappa, "#6b7280",
                v => ComputeFinalGap(_divAlpha, _divStruggle0, _divGamma, _divM, _divBeta, v)),
        };

        var series = new List<ChartSeries>();
        var markers = new List<ChartMarker>();
        double maxSensitivity = 0;
        string mostSensitive = "";

        for (int p = 0; p < paramDefs.Length; p++)
        {
            var def = paramDefs[p];
            var pts = new List<DataPoint>();
            const int sweepSteps = 50;

            for (int i = 0; i <= sweepSteps; i++)
            {
                double normalized = (double)i / sweepSteps;
                double paramVal = def.Min + normalized * (def.Max - def.Min);
                double gap = def.GapAt(paramVal);
                pts.Add(new DataPoint(normalized, gap));
            }

            series.Add(new ChartSeries($"{def.Name}", pts, def.Color, 2.0));

            // Current value marker
            double currentNorm = (def.Max - def.Min) > 0 ? (def.Current - def.Min) / (def.Max - def.Min) : 0.5;
            double currentGap = def.GapAt(def.Current);
            markers.Add(new ChartMarker(currentNorm, currentGap, def.Color, null, new List<string>
            {
                def.Name,
                $"Value: {def.Current:F2} (range {def.Min:F1}\u2013{def.Max:F1})",
                $"Gap at current: {currentGap:F1}"
            }));

            // Track sensitivity (range of gap values)
            double gapAtMin = def.GapAt(def.Min);
            double gapAtMax = def.GapAt(def.Max);
            double sensitivity = Math.Abs(gapAtMax - gapAtMin);
            if (sensitivity > maxSensitivity)
            {
                maxSensitivity = sensitivity;
                mostSensitive = def.Name;
            }
        }

        _sensitivitySeries = series;
        _sensitivityMarkers = markers;
        _mostSensitiveParam = mostSensitive;
    }

    private double ComputeFinalGap(double alpha, double s0, double gamma, double m, double beta, double kappa)
    {
        double[] y0 = { _divFH0, _divFL0 };
        double dt = 0.2; // coarser for sensitivity sweep performance
        double[][] result = Integration.ForwardEulerSystem(y0, 0.0, 20.0, dt,
            (t, y) => new[]
            {
                DivergenceTrajectories.DfHighDt(alpha, s0, gamma, m, y[0]),
                DivergenceTrajectories.DfLowDt(alpha, s0, beta, m, kappa, y[1])
            });
        int last = result[0].Length - 1;
        return result[0][last] - result[1][last];
    }

    // ─── Generational Step-Down ───
    private void RecalcGenerational()
    {
        double alpha = _divAlpha;
        double struggle0 = _divStruggle0;
        double gamma = _divGamma;
        double m = _divM;

        string[] colors = { "#dc2626", "#f59e0b", "#10b981", "#2563eb" };
        double tStart = 0.0, tEnd = 20.0, dt = 0.1;

        var series = new List<ChartSeries>();
        var markers = new List<ChartMarker>();
        var ceilings = new double[_genSAvails.Length];

        for (int g = 0; g < _genSAvails.Length; g++)
        {
            double fInit = DivergenceTrajectories.InitialForce(_genForceMax, _genSAvails[g], _genStrugglePre, _genRho);
            ceilings[g] = fInit;
            double[] trajectory = Integration.ForwardEuler(fInit, tStart, tEnd, dt,
                (t, f) => DivergenceTrajectories.DfHighDt(alpha, struggle0, gamma, m, f));

            var pts = new List<DataPoint>(trajectory.Length);
            for (int i = 0; i < trajectory.Length; i++)
                pts.Add(new DataPoint(tStart + i * dt, trajectory[i]));

            double finalVal = trajectory[trajectory.Length - 1];
            series.Add(new ChartSeries($"S_avail={_genSAvails[g]:F0} (F\u2080={fInit:F1})", pts, colors[g], 2.0));
            markers.Add(new ChartMarker(20.0, finalVal, colors[g], null, new List<string>
            {
                $"Cohort: S_avail={_genSAvails[g]:F0}",
                $"F\u2080 = {fInit:F1} (Eq 32)",
                $"F(20) = {finalVal:F1}",
                $"Growth: {((finalVal / Math.Max(fInit, 0.01)) - 1):P0}"
            }));
        }

        _genSeries = series;
        _genMarkers = markers;
        _genCeilings = ceilings;
    }

