@page "/base-model"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Force is Not a Number — Eq (1), (1a), (2), (3)</PageTitle>

<h1>Force is Not a Number — Eq (1), (1a), (2), (3)</h1>

<blockquote>
    Output is not the sum of its parts; it is a product. The Cobb-Douglas structure means that zeroing any single force dimension collapses the entire output, no matter how strong the others. The multiplier M acts as a scaling lens on this product.
</blockquote>


@* ──────────────────────────────────────────────────────────────────────── *@
@* Eq (1): Cobb-Douglas Output — HeatMap                                  *@
@* ──────────────────────────────────────────────────────────────────────── *@

<div id="base-model-chart-0">
<ChartCard Title="Cobb-Douglas Output Surface"
           Description="Eq (1): O = M * product(fi^wi). Axes show two force components; M and all other forces held at slider values. Move any slider to see the surface shift.">
    <ChildContent>
        <div style="display: flex; gap: 16px; align-items: flex-start; flex-wrap: wrap;">
            <HeatMap Width="600" Height="400"
                     XLabel="@(_componentLabels[_heatAxisX] + " (f" + (_heatAxisX + 1) + ")")"
                     YLabel="@(_componentLabels[_heatAxisY] + " (f" + (_heatAxisY + 1) + ")")"
                     Data="@_heatMapData"
                     XValues="@_heatMapXValues"
                     YValues="@_heatMapYValues"
                     CrosshairX="@GetForces()[_heatAxisX]"
                     CrosshairY="@GetForces()[_heatAxisY]"
                     CrosshairTooltip="@_heatTooltipLines"
                     ColorScaleMin="0"
                     ColorScaleMax="@_heatColorMax" />
            <div>
                <p style="text-align: center; font-size: 0.85em; font-weight: 600; margin: 0 0 4px;">Force Profile</p>
                <RadarChart Width="280" Height="280"
                            Axes="@_radarAxes"
                            CenterLabel="@("F=" + ComputeCurrentForce().ToString("F1"))" />
            </div>
        </div>
        <p class="chart-readout">
            Current output: <strong>O = @ComputeCurrentOutput().ToString("F2")</strong>
            &ensp;|&ensp;M=@_m.ToString("F1")
            &ensp;|&ensp;F=@ComputeCurrentForce().ToString("F2")
        </p>
        <p class="chart-readout" style="font-size: 0.85em; opacity: 0.7;">
            Heatmap axes: @_componentLabels[_heatAxisX] vs @_componentLabels[_heatAxisY].
            All other components held at their slider values.
            Color scale fixed at 0 to @_heatColorMax.ToString("F0") so M changes are visible.
        </p>
    </ChildContent>
    <TheoryContent>
        <h4>Equation</h4>
        <KatexBlock Latex="O = M \times F \quad \text{where} \quad F = \prod_{i} f_i^{w_i} \qquad (1)" />
        <h4>In Plain Language</h4>
        <p>O is your productive output. M is the LLM's amplification factor. F is your composite human capability, your Force. Each capability component f_i (domain expertise, architectural judgment, taste, clarity of specification, debugging intuition, calibrated uncertainty, intrinsic motivation) is raised to the power of its weight w_i, where w_i represents how much that component matters for the task at hand. The weights sum to 1, representing proportional importance. The mathematical consequence of this multiplicative form is decisive: if any critical component approaches zero, Force collapses toward zero regardless of how strong the others are. A brilliant architect with zero domain knowledge does not produce "slightly worse" output; the zero term drags the entire product down.</p>
        <h4>Reading the Charts</h4>
        <p>The heatmap sweeps two force components while M and all others are held at slider values. The red crosshair marks your current position on the surface. The radar chart beside it shows all 7 components at once as a polygon; a balanced profile fills the shape evenly, while a weakness shows as a visible dent. The color scale is fixed so that changing M produces visible color shifts, not just readout changes.</p>
        <h4>The Mirror</h4>
        <p>You cannot place a question before the mirror that exhibits precision you don't possess. The reflection is faithful along the substance channel; it gives back what you brought, no more and no less. The senior engineer's precise question produced a precise reflection. The junior engineer's vague question produced a vague one. The mirror did not generate the difference. The Force did.</p>
        <h4>Connections</h4>
        <ul>
            <li>Layer hierarchy: <strong>Eq (1a)</strong></li>
            <li>Variance amplification: <strong>Eq (4)</strong></li>
            <li>Force dynamics: <strong>Eq (11)</strong></li>
        </ul>
    </TheoryContent>
</ChartCard>
</div>

@* ──────────────────────────────────────────────────────────────────────── *@
@* Eq (1): Force Component Sensitivity                                    *@
@* ──────────────────────────────────────────────────────────────────────── *@

<div id="base-model-chart-1">
<ChartCard Title="Force Component Sensitivity"
           Description="Eq (1): How output changes as each force component varies, holding all others at their slider values.">
    <ChildContent>
        <LineChart Width="600" Height="400"
                   XLabel="Component Value (fi)"
                   YLabel="Output (O)"
                   Series="@_sensitivitySeries"
                   YMin="0"
                   Markers="@_sensitivityMarkers"
                   HighlightSeriesIndices="@_sensitivityHighlight" />
        <p class="chart-readout" style="font-size: 0.85em; opacity: 0.7;">
            Dashed curves correspond to the heatmap axes.
            Dots mark each component's current slider value.
        </p>
    </ChildContent>
    <TheoryContent>
        <h4>Why This Matters</h4>
        <p>Each curve shows how output responds to a single force component while all others stay fixed. Components with higher weights produce steeper curves. A component near zero drags the entire product down regardless of others, which is the Cobb-Douglas "one zero kills the product" property.</p>
        <h4>Reading the Chart</h4>
        <p>Steeper curves indicate higher sensitivity. The dots on each curve mark the current slider value: your "you are here" for all 7 components in one view. Dashed, thicker curves correspond to the two components currently displayed on the heatmap axes, linking the two charts visually. If curves are clustered, the weights are similar; if one is much steeper, that component dominates the output.</p>
    </TheoryContent>
</ChartCard>
</div>

@* ──────────────────────────────────────────────────────────────────────── *@
@* Eq (1a): Layer Effective Multiplier                                    *@
@* ──────────────────────────────────────────────────────────────────────── *@

<div id="base-model-chart-2">
<ChartCard Title="Layer Effective Multiplier"
           Description="Eq (1a): M_eff by layer. The LLM substitutes almost fully at the surface, partially in the middle, and barely at depth.">
    <ChildContent>
        <BarChart Bars="@_layerBars" XLabel="Layer" YLabel="Layer Output (M_eff × F)" />
        <ThresholdIndicator Label="@(_layerValid ? "Layer ordering valid: surface >> middle > deep ≈ 1" : "Layer ordering violated")" Passed="@_layerValid" />
    </ChildContent>
    <TheoryContent>
        <h4>Equation</h4>
        <KatexBlock Latex="M_{\text{eff}}^{\text{surface}} \gg M_{\text{eff}}^{\text{middle}} > M_{\text{eff}}^{\text{deep}} \approx 1 \qquad (1a)" />
        <h4>In Plain Language</h4>
        <p>The LLM is an almost perfect substitute for the surface layer (syntax, APIs, with high M_eff), a partial substitute for the middle layer (judgment, taste, with moderate M_eff), and barely a substitute at all for the deep layer (structural intuition, where M_eff is approximately 1). Surface knowledge has a half-life of months, middle of years, deep of decades.</p>
        <h4>The Mirror</h4>
        <p>The mirror's fidelity at the surface conceals its limitations at depth.</p>
        <h4>Connections</h4>
        <ul>
            <li>Barbell effect: <strong>Eq (6)</strong></li>
            <li>Layered decay: <strong>Eq (11a-c)</strong></li>
            <li>Transfer efficiency: <strong>Eq (26a)</strong></li>
        </ul>
    </TheoryContent>
</ChartCard>
</div>

@* ──────────────────────────────────────────────────────────────────────── *@
@* Eq (2): Variable Multiplier Across Domains                            *@
@* ──────────────────────────────────────────────────────────────────────── *@

<div id="base-model-chart-3">
<ChartCard Title="Variable Multiplier Across Domains"
           Description="Eq (2): O = sum(Ms(d) * F(d)). Total output is the sum of domain-specific contributions.">
    <ChildContent>
        <BarChart StackedBars="@_domainStacks" XLabel="Domain" YLabel="Domain Output" />
        <p class="chart-readout">
            Total cross-domain output: <strong>@_domainTotal.ToString("F2")</strong>
        </p>
    </ChildContent>
    <TheoryContent>
        <h4>Equation</h4>
        <KatexBlock Latex="O = \sum_{d} M_s(d) \times F(d) \qquad (2)" />
        <h4>In Plain Language</h4>
        <p>Instead of a single multiplier applied once, total output sums the contribution from each domain separately. Within a domain, Force components combine multiplicatively (one zero kills the product), but across domains the contributions combine additively. The LLM might be a 50x substance multiplier for boilerplate CRUD, 1.3x for novel architecture, and less than 1x for debugging a production race condition.</p>
        <h4>The Mirror</h4>
        <p>The mirror's fidelity varies by what you're reflecting. Simple, well-structured patterns reflect cleanly. Novel, ambiguous designs reflect poorly; the distortion can be worse than no reflection at all.</p>
        <h4>Connections</h4>
        <ul>
            <li>Skill value sensitivity: <strong>Eq (3)</strong></li>
            <li>Sovereignty: <strong>Eq (35+)</strong></li>
        </ul>
    </TheoryContent>
</ChartCard>
</div>

@* ──────────────────────────────────────────────────────────────────────── *@
@* Eq (3): Skill Value Sensitivity                                        *@
@* ──────────────────────────────────────────────────────────────────────── *@

<div id="base-model-chart-4">
<ChartCard Title="Skill Value Sensitivity by Domain"
           Description="Eq (3): dVs/dIp = (dMs(d)/dIp) * F_bar_s. Each curve shows how provider investment changes a domain's skill value, shaped by both the multiplier improvement rate and the average Force in that domain.">
    <ChildContent>
        <LineChart Width="600" Height="400"
                   XLabel="Provider Investment (Ip)"
                   YLabel="Change in Skill Value (dVs/dIp)"
                   Series="@_skillValueSeries"
                   YMin="0" />
        <p class="chart-readout">
            At current investment level:
            @foreach (var entry in _skillReadouts)
            {
                <span>&ensp;|&ensp;@entry.Key: <strong>@entry.Value.ToString("F2")</strong></span>
            }
        </p>
    </ChildContent>
    <TheoryContent>
        <h4>Equation</h4>
        <KatexBlock Latex="\frac{\partial V_s}{\partial I_p} = \frac{\partial M_s(d)}{\partial I_p} \times \bar{F}_s \qquad (3)" />
        <h4>In Plain Language</h4>
        <p>V_s is the market value of skill s. I_p is the LLM provider's investment in training capability for domain d. The partial derivative dMs(d)/dIp measures how much the provider's investment improves the substance multiplier in that domain. F_bar_s is the average Force of engineers in skill s. The equation says: whoever decides where the LLM gets better is implicitly deciding which skills become more economically valuable. The magnitude of the reshaping depends on both how much the multiplier improves and how much human Force exists to be multiplied.</p>
        <h4>Reading the Chart</h4>
        <p>Each curve represents a domain. Domains where the LLM improves rapidly (high dMs/dIp) and where substantial human Force exists see the largest shift in skill value. Domains with low multiplier sensitivity or low average Force barely move. The crossing points reveal where provider investment flips the relative economic value of two skills.</p>
        <h4>Connections</h4>
        <ul>
            <li>Variable multiplier: <strong>Eq (2)</strong></li>
            <li>Barbell effect: <strong>Eq (6)</strong></li>
            <li>Sovereignty: <strong>Eq (35+)</strong></li>
        </ul>
    </TheoryContent>
</ChartCard>
</div>

@* ──────────────────────────────────────────────────────────────────────── *@
@* Slider Panel                                                           *@
@* ──────────────────────────────────────────────────────────────────────── *@

<FloatingSliderPanel Visible="true" Title="Base Model Parameters" DefaultY="100">
    <PresetContent>
        <button @onclick="() => ApplyPreset(Preset.BalancedSenior)">Balanced Senior</button>
        <button @onclick="() => ApplyPreset(Preset.MissingCriticalSkill)">Missing Critical Skill</button>
        <button @onclick="() => ApplyPreset(Preset.JuniorEngineer)">Junior Engineer</button>
    </PresetContent>
    <ChildContent>

    <div class="slider-context-label">
        @if (_showAllSliders)
        {
            <span>Showing all sliders</span>
        }
        else if (_activeChartIndex >= 0 && _activeChartIndex < BaseChartNames.Length)
        {
            <span>Sliders for: @BaseChartNames[_activeChartIndex]</span>
        }
        &ensp;
        <button class="slider-show-all-toggle" @onclick="ToggleShowAll">
            @(_showAllSliders ? "Auto-filter" : "Show all")
        </button>
    </div>

    @* Group 0: Heatmap Axes *@
    @if (IsGroupVisible(0))
    {
        <div class="slider-group-header">Eq (1): Heatmap Axes</div>
    }
    <div class="slider-slot @GroupSlotClass(0)">
        <ParameterSlider Label="X-axis component (1-7)" Min="1" Max="7" Step="1" Value="@(_heatAxisX + 1)" ValueChanged="v => { _heatAxisX = (int)v - 1; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(0)">
        <ParameterSlider Label="Y-axis component (1-7)" Min="1" Max="7" Step="1" Value="@(_heatAxisY + 1)" ValueChanged="v => { _heatAxisY = (int)v - 1; Recalculate(); }" />
    </div>

    @* Group 1: Force Components *@
    @if (IsGroupVisible(1))
    {
        <div class="slider-group-header">Eq (1): Force Components</div>
    }
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="M (Multiplier)" Min="0.5" Max="5" Step="0.1" Value="@_m" ValueChanged="OnMChanged" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f1: Domain Expertise" Min="0" Max="10" Step="0.1" Value="@_f1" ValueChanged="v => { _f1 = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f2: Arch. Judgment" Min="0" Max="10" Step="0.1" Value="@_f2" ValueChanged="v => { _f2 = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f3: Taste" Min="0" Max="10" Step="0.1" Value="@_f3" ValueChanged="v => { _f3 = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f4: Spec Clarity" Min="0" Max="10" Step="0.1" Value="@_f4" ValueChanged="v => { _f4 = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f5: Debug Intuition" Min="0" Max="10" Step="0.1" Value="@_f5" ValueChanged="v => { _f5 = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f6: Calibrated Uncert." Min="0" Max="10" Step="0.1" Value="@_f6" ValueChanged="v => { _f6 = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(1)">
        <ParameterSlider Label="f7: Intrinsic Motiv." Min="0" Max="10" Step="0.1" Value="@_f7" ValueChanged="v => { _f7 = v; Recalculate(); }" />
    </div>

    @* Group 2: Weights *@
    @if (IsGroupVisible(2))
    {
        <div class="slider-group-header">Eq (1): Weights (sum to 1)</div>
    }
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w1: Domain Expertise" Min="0.01" Max="0.5" Step="0.01" Value="@_w1" ValueChanged="v => { _w1 = v; NormalizeWeights(0); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w2: Arch. Judgment" Min="0.01" Max="0.5" Step="0.01" Value="@_w2" ValueChanged="v => { _w2 = v; NormalizeWeights(1); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w3: Taste" Min="0.01" Max="0.5" Step="0.01" Value="@_w3" ValueChanged="v => { _w3 = v; NormalizeWeights(2); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w4: Spec Clarity" Min="0.01" Max="0.5" Step="0.01" Value="@_w4" ValueChanged="v => { _w4 = v; NormalizeWeights(3); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w5: Debug Intuition" Min="0.01" Max="0.5" Step="0.01" Value="@_w5" ValueChanged="v => { _w5 = v; NormalizeWeights(4); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w6: Calibrated Uncert." Min="0.01" Max="0.5" Step="0.01" Value="@_w6" ValueChanged="v => { _w6 = v; NormalizeWeights(5); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(2)">
        <ParameterSlider Label="w7: Intrinsic Motiv." Min="0.01" Max="0.5" Step="0.01" Value="@_w7" ValueChanged="v => { _w7 = v; NormalizeWeights(6); }" />
    </div>

    @* Group 3: Layer Effective Multipliers *@
    @if (IsGroupVisible(3))
    {
        <div class="slider-group-header">Eq (1a): Layer Effective Multipliers</div>
    }
    <div class="slider-slot @GroupSlotClass(3)">
        <ParameterSlider Label="M_eff Surface" Min="1" Max="50" Step="0.5" Value="@_mEffSurface" ValueChanged="v => { _mEffSurface = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(3)">
        <ParameterSlider Label="M_eff Middle" Min="1" Max="10" Step="0.1" Value="@_mEffMiddle" ValueChanged="v => { _mEffMiddle = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(3)">
        <ParameterSlider Label="M_eff Deep" Min="0.5" Max="3" Step="0.1" Value="@_mEffDeep" ValueChanged="v => { _mEffDeep = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(3)">
        <ParameterSlider Label="Force (Surface)" Min="0" Max="10" Step="0.1" Value="@_forceSurface" ValueChanged="v => { _forceSurface = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(3)">
        <ParameterSlider Label="Force (Middle)" Min="0" Max="10" Step="0.1" Value="@_forceMiddle" ValueChanged="v => { _forceMiddle = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(3)">
        <ParameterSlider Label="Force (Deep)" Min="0" Max="10" Step="0.1" Value="@_forceDeep" ValueChanged="v => { _forceDeep = v; Recalculate(); }" />
    </div>

    @* Group 4: Domain Multipliers *@
    @if (IsGroupVisible(4))
    {
        <div class="slider-group-header">Eq (2): Domain Multipliers</div>
    }
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="Ms: Boilerplate" Min="0.5" Max="50" Step="0.5" Value="@_msBoilerplate" ValueChanged="v => { _msBoilerplate = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="Ms: Integration" Min="0.5" Max="20" Step="0.5" Value="@_msIntegration" ValueChanged="v => { _msIntegration = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="Ms: Architecture" Min="0.5" Max="5" Step="0.1" Value="@_msArchitecture" ValueChanged="v => { _msArchitecture = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="Ms: Debugging" Min="0.1" Max="3" Step="0.1" Value="@_msDebugging" ValueChanged="v => { _msDebugging = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="F: Boilerplate" Min="0" Max="10" Step="0.1" Value="@_fdBoilerplate" ValueChanged="v => { _fdBoilerplate = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="F: Integration" Min="0" Max="10" Step="0.1" Value="@_fdIntegration" ValueChanged="v => { _fdIntegration = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="F: Architecture" Min="0" Max="10" Step="0.1" Value="@_fdArchitecture" ValueChanged="v => { _fdArchitecture = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(4)">
        <ParameterSlider Label="F: Debugging" Min="0" Max="10" Step="0.1" Value="@_fdDebugging" ValueChanged="v => { _fdDebugging = v; Recalculate(); }" />
    </div>

    @* Group 5: Skill Value Sensitivity *@
    @if (IsGroupVisible(5))
    {
        <div class="slider-group-header">Eq (3): Skill Value Sensitivity</div>
    }
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="Ip (current investment)" Min="0.1" Max="10" Step="0.1" Value="@_currentIp" ValueChanged="v => { _currentIp = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="dMs/dIp: Boilerplate" Min="0.1" Max="10" Step="0.1" Value="@_dMsBoilerplate" ValueChanged="v => { _dMsBoilerplate = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="dMs/dIp: Integration" Min="0.1" Max="10" Step="0.1" Value="@_dMsIntegration" ValueChanged="v => { _dMsIntegration = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="dMs/dIp: Architecture" Min="0.1" Max="10" Step="0.1" Value="@_dMsArchitecture" ValueChanged="v => { _dMsArchitecture = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="dMs/dIp: Debugging" Min="0.1" Max="10" Step="0.1" Value="@_dMsDebugging" ValueChanged="v => { _dMsDebugging = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="F_bar: Boilerplate" Min="0.5" Max="10" Step="0.1" Value="@_fBarBoilerplate" ValueChanged="v => { _fBarBoilerplate = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="F_bar: Integration" Min="0.5" Max="10" Step="0.1" Value="@_fBarIntegration" ValueChanged="v => { _fBarIntegration = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="F_bar: Architecture" Min="0.5" Max="10" Step="0.1" Value="@_fBarArchitecture" ValueChanged="v => { _fBarArchitecture = v; Recalculate(); }" />
    </div>
    <div class="slider-slot @GroupSlotClass(5)">
        <ParameterSlider Label="F_bar: Debugging" Min="0.5" Max="10" Step="0.1" Value="@_fBarDebugging" ValueChanged="v => { _fBarDebugging = v; Recalculate(); }" />
    </div>

    </ChildContent>
</FloatingSliderPanel>

@code {
    private enum Preset { BalancedSenior, MissingCriticalSkill, JuniorEngineer }

    // ── Scroll-aware slider state ──
    private int _activeChartIndex = 0;
    private bool _showAllSliders;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<BaseModelPage>? _dotNetRef;

    private static readonly string[] BaseChartNames =
    {
        "Cobb-Douglas Surface",
        "Component Sensitivity",
        "Layer Multiplier",
        "Domain Multipliers",
        "Skill Value Sensitivity"
    };

    // Per-chart: which slider groups (indices) are visible
    // Group 0 = Heatmap Axes, 1 = Force Components, 2 = Weights,
    // 3 = Layer M_eff, 4 = Domain, 5 = Skill Value
    private static readonly HashSet<int>[] ChartVisibleGroups =
    {
        new() { 0, 1, 2 }, // Chart 0: HeatMap
        new() { 0, 1, 2 }, // Chart 1: Sensitivity
        new() { 3 },       // Chart 2: Layer
        new() { 4 },       // Chart 3: Domain
        new() { 5 },       // Chart 4: Skill Value
    };

    private bool IsGroupVisible(int groupIndex) =>
        _showAllSliders ||
        (_activeChartIndex >= 0 && _activeChartIndex < ChartVisibleGroups.Length &&
         ChartVisibleGroups[_activeChartIndex].Contains(groupIndex));

    private string GroupSlotClass(int groupIndex) => IsGroupVisible(groupIndex) ? "" : "hidden";

    private void ToggleShowAll() => _showAllSliders = !_showAllSliders;

    private static readonly string[] ChartElementIds =
    {
        "base-model-chart-0", "base-model-chart-1", "base-model-chart-2",
        "base-model-chart-3", "base-model-chart-4"
    };

    [JSInvokable]
    public void OnChartScrolled(int index)
    {
        if (index == _activeChartIndex) return;
        _activeChartIndex = index;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/FStar.UI/FStar.UI.lib.module.js");
                _dotNetRef = DotNetObjectReference.Create(this);
                await _jsModule.InvokeVoidAsync(
                    "initChartObserver", _dotNetRef, "OnChartScrolled", ChartElementIds);
            }
            catch (JSException) { /* SSR / prerender guard */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("destroyChartObserver");
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _dotNetRef?.Dispose();
    }

    // ── Eq (1): Base output parameters ──
    private double _m = 2.0;

    // Heatmap axis selection (which two force components to sweep)
    private int _heatAxisX = 0; // f1: Domain Expertise
    private int _heatAxisY = 1; // f2: Arch. Judgment

    private static readonly string[] _componentLabels = {
        "Domain Expertise", "Arch. Judgment", "Taste",
        "Spec Clarity", "Debug Intuition", "Calibrated Uncert.", "Intrinsic Motiv."
    };

    // Force components (the 7 listed in the concept document)
    private double _f1 = 7.0;  // Domain expertise
    private double _f2 = 6.0;  // Architectural judgment
    private double _f3 = 5.0;  // Taste
    private double _f4 = 6.0;  // Specification clarity
    private double _f5 = 7.0;  // Debugging intuition
    private double _f6 = 5.0;  // Calibrated uncertainty
    private double _f7 = 6.0;  // Intrinsic motivation

    // Weights (sum to 1)
    private double _w1 = 0.20;
    private double _w2 = 0.18;
    private double _w3 = 0.10;
    private double _w4 = 0.15;
    private double _w5 = 0.15;
    private double _w6 = 0.12;
    private double _w7 = 0.10;

    // ── Eq (1a): Layer-specific effective multipliers ──
    private double _mEffSurface = 20.0;
    private double _mEffMiddle = 3.0;
    private double _mEffDeep = 1.2;
    private double _forceSurface = 4.0;
    private double _forceMiddle = 6.0;
    private double _forceDeep = 8.0;

    // ── Eq (2): Domain multipliers and forces ──
    private double _msBoilerplate = 30.0;
    private double _msIntegration = 5.0;
    private double _msArchitecture = 1.3;
    private double _msDebugging = 0.8;
    private double _fdBoilerplate = 3.0;
    private double _fdIntegration = 5.0;
    private double _fdArchitecture = 7.0;
    private double _fdDebugging = 8.0;

    // ── Eq (3): Per-domain skill value sensitivity ──
    private double _currentIp = 3.0;
    private double _dMsBoilerplate = 8.0;   // high: LLM improves fast here
    private double _dMsIntegration = 4.0;
    private double _dMsArchitecture = 1.5;  // low: novel work, slow improvement
    private double _dMsDebugging = 0.5;     // very low: LLM struggles here
    private double _fBarBoilerplate = 3.0;  // low avg Force (many juniors)
    private double _fBarIntegration = 5.0;
    private double _fBarArchitecture = 7.0; // high avg Force (seniors)
    private double _fBarDebugging = 8.0;    // highest avg Force

    // ── Chart data ──
    private double[,] _heatMapData = new double[0, 0];
    private double[] _heatMapXValues = Array.Empty<double>();
    private double[] _heatMapYValues = Array.Empty<double>();
    private double _heatColorMax = 50.0;
    private List<string> _heatTooltipLines = new();
    private List<ChartSeries> _sensitivitySeries = new();
    private List<ChartMarker> _sensitivityMarkers = new();
    private HashSet<int> _sensitivityHighlight = new();
    private List<RadarAxis> _radarAxes = new();
    private List<BarItem> _layerBars = new();
    private bool _layerValid;
    private List<BarStack> _domainStacks = new();
    private double _domainTotal;
    private List<ChartSeries> _skillValueSeries = new();
    private Dictionary<string, double> _skillReadouts = new();

    protected override void OnInitialized() => ApplyPreset(Preset.BalancedSenior);

    private void ApplyPreset(Preset preset)
    {
        switch (preset)
        {
            case Preset.BalancedSenior:
                _m = 2.0; _f1 = 7.0; _f2 = 6.0; _f3 = 5.0; _f4 = 6.0; _f5 = 7.0; _f6 = 5.0; _f7 = 6.0;
                _w1 = 0.20; _w2 = 0.18; _w3 = 0.10; _w4 = 0.15; _w5 = 0.15; _w6 = 0.12; _w7 = 0.10;
                _mEffSurface = 20.0; _mEffMiddle = 3.0; _mEffDeep = 1.2;
                _forceSurface = 4.0; _forceMiddle = 6.0; _forceDeep = 8.0;
                _msBoilerplate = 30.0; _msIntegration = 5.0; _msArchitecture = 1.3; _msDebugging = 0.8;
                _fdBoilerplate = 3.0; _fdIntegration = 5.0; _fdArchitecture = 7.0; _fdDebugging = 8.0;
                _currentIp = 3.0; _dMsBoilerplate = 8.0; _dMsIntegration = 4.0; _dMsArchitecture = 1.5; _dMsDebugging = 0.5;
                _fBarBoilerplate = 3.0; _fBarIntegration = 5.0; _fBarArchitecture = 7.0; _fBarDebugging = 8.0;
                break;
            case Preset.MissingCriticalSkill:
                _m = 3.0; _f1 = 0.5; _f2 = 9.0; _f3 = 7.0; _f4 = 8.0; _f5 = 2.0; _f6 = 3.0; _f7 = 7.0;
                _w1 = 0.20; _w2 = 0.18; _w3 = 0.10; _w4 = 0.15; _w5 = 0.15; _w6 = 0.12; _w7 = 0.10;
                _mEffSurface = 20.0; _mEffMiddle = 3.0; _mEffDeep = 1.2;
                _forceSurface = 4.0; _forceMiddle = 6.0; _forceDeep = 8.0;
                _msBoilerplate = 30.0; _msIntegration = 5.0; _msArchitecture = 1.3; _msDebugging = 0.8;
                _fdBoilerplate = 3.0; _fdIntegration = 5.0; _fdArchitecture = 7.0; _fdDebugging = 8.0;
                _currentIp = 3.0; _dMsBoilerplate = 8.0; _dMsIntegration = 4.0; _dMsArchitecture = 1.5; _dMsDebugging = 0.5;
                _fBarBoilerplate = 3.0; _fBarIntegration = 5.0; _fBarArchitecture = 7.0; _fBarDebugging = 8.0;
                break;
            case Preset.JuniorEngineer:
                _m = 3.0; _f1 = 2.0; _f2 = 2.0; _f3 = 2.0; _f4 = 3.0; _f5 = 1.5; _f6 = 1.5; _f7 = 5.0;
                _w1 = 0.20; _w2 = 0.18; _w3 = 0.10; _w4 = 0.15; _w5 = 0.15; _w6 = 0.12; _w7 = 0.10;
                _mEffSurface = 20.0; _mEffMiddle = 3.0; _mEffDeep = 1.2;
                _forceSurface = 4.0; _forceMiddle = 6.0; _forceDeep = 8.0;
                _msBoilerplate = 30.0; _msIntegration = 5.0; _msArchitecture = 1.3; _msDebugging = 0.8;
                _fdBoilerplate = 3.0; _fdIntegration = 5.0; _fdArchitecture = 7.0; _fdDebugging = 8.0;
                _currentIp = 3.0; _dMsBoilerplate = 8.0; _dMsIntegration = 4.0; _dMsArchitecture = 1.5; _dMsDebugging = 0.5;
                _fBarBoilerplate = 3.0; _fBarIntegration = 5.0; _fBarArchitecture = 7.0; _fBarDebugging = 8.0;
                break;
        }
        Recalculate();
    }

    private void OnMChanged(double v) { _m = v; Recalculate(); }

    private double[] GetForces() => new[] { _f1, _f2, _f3, _f4, _f5, _f6, _f7 };
    private double[] GetWeights() => new[] { _w1, _w2, _w3, _w4, _w5, _w6, _w7 };

    private void NormalizeWeights(int changedIndex)
    {
        // Re-normalize other weights so all sum to 1
        var weights = GetWeights();
        double changedVal = weights[changedIndex];
        double sumOthers = 0;
        for (int i = 0; i < weights.Length; i++)
            if (i != changedIndex) sumOthers += weights[i];

        if (sumOthers > 0)
        {
            double remaining = 1.0 - changedVal;
            double scale = remaining / sumOthers;
            var normalized = new double[weights.Length];
            for (int i = 0; i < weights.Length; i++)
                normalized[i] = i == changedIndex ? changedVal : weights[i] * scale;

            _w1 = normalized[0]; _w2 = normalized[1]; _w3 = normalized[2];
            _w4 = normalized[3]; _w5 = normalized[4]; _w6 = normalized[5];
            _w7 = normalized[6];
        }
        Recalculate();
    }

    private double ComputeCurrentForce()
    {
        var forces = GetForces();
        var weights = GetWeights();
        double product = 1.0;
        for (int i = 0; i < forces.Length; i++)
            product *= Math.Pow(Math.Max(forces[i], 1e-6), weights[i]);
        return product;
    }

    private double ComputeCurrentOutput() => _m * ComputeCurrentForce();

    private void Recalculate()
    {
        ComputeHeatMap();
        ComputeSensitivity();
        ComputeRadarAxes();
        ComputeLayerBars();
        ComputeDomainBars();
        ComputeSkillValueSeries();
    }

    // ── Eq (1) HeatMap: sweep two user-selected force components ──
    private void ComputeHeatMap()
    {
        const int steps = 25;
        _heatMapXValues = new double[steps];
        _heatMapYValues = new double[steps];
        _heatMapData = new double[steps, steps];

        var forces = GetForces();
        var weights = GetWeights();

        // Prevent same axis for both dimensions
        int axisY = _heatAxisY == _heatAxisX
            ? (_heatAxisX + 1) % forces.Length
            : _heatAxisY;

        // Both axes sweep 0.1 to 10
        for (int i = 0; i < steps; i++)
            _heatMapXValues[i] = 0.1 + i * 9.9 / (steps - 1);
        for (int j = 0; j < steps; j++)
            _heatMapYValues[j] = 0.1 + j * 9.9 / (steps - 1);

        for (int r = 0; r < steps; r++)
        {
            for (int c = 0; c < steps; c++)
            {
                var testForces = (double[])forces.Clone();
                testForces[_heatAxisX] = _heatMapXValues[c];
                testForces[axisY] = _heatMapYValues[r];
                _heatMapData[r, c] = BaseModel.ComputeOutput(_m, testForces, weights);
            }
        }

        // Fixed color scale: compute the theoretical max at M=5, all forces=10
        // This makes M changes and force changes produce visible color shifts
        var maxForces = new double[forces.Length];
        Array.Fill(maxForces, 10.0);
        _heatColorMax = BaseModel.ComputeOutput(Math.Max(_m, 5.0), maxForces, weights);

        // Build tooltip lines for the crosshair
        var currentO = ComputeCurrentOutput();
        var currentF = ComputeCurrentForce();
        _heatTooltipLines = new List<string>
        {
            $"Your current position",
            $"{_componentLabels[_heatAxisX]} = {forces[_heatAxisX]:F1}",
            $"{_componentLabels[axisY]} = {forces[axisY]:F1}",
            $"M = {_m:F1}, F = {currentF:F2}",
            $"Output O = {currentO:F2}",
            $"Other 5 components held at sliders"
        };
    }

    // ── Eq (1) Sensitivity: one line per force component ──
    private void ComputeSensitivity()
    {
        var forces = GetForces();
        var weights = GetWeights();
        var labels = new[] {
            "Domain Expertise", "Arch. Judgment", "Taste",
            "Spec Clarity", "Debug Intuition", "Calibrated Uncert.", "Intrinsic Motiv."
        };
        var colors = new[] { "#2563eb", "#dc2626", "#16a34a", "#9333ea", "#ea580c", "#0891b2", "#d946ef" };
        const int pts = 50;

        _sensitivitySeries = new List<ChartSeries>();
        _sensitivityMarkers = new List<ChartMarker>();
        _sensitivityHighlight = new HashSet<int> { _heatAxisX, _heatAxisY };

        for (int comp = 0; comp < forces.Length; comp++)
        {
            var points = new List<DataPoint>();
            for (int p = 0; p < pts; p++)
            {
                double fi = 0.1 + p * 9.9 / (pts - 1);
                var testForces = (double[])forces.Clone();
                testForces[comp] = fi;
                double output = BaseModel.ComputeOutput(_m, testForces, weights);
                points.Add(new DataPoint(fi, output));
            }
            _sensitivitySeries.Add(new ChartSeries(labels[comp], points, colors[comp], 2.0, false));

            // Add a marker dot at the current slider value for this component
            double currentFi = forces[comp];
            double currentOutput = BaseModel.ComputeOutput(_m, forces, weights);
            var isAxis = comp == _heatAxisX || comp == _heatAxisY;
            var markerTooltip = new List<string>
            {
                $"{labels[comp]} (f{comp + 1})",
                $"Value = {currentFi:F1}, Weight = {weights[comp]:F2}",
                $"Output O = {currentOutput:F2}",
                isAxis ? "Currently on heatmap axis" : "Held fixed on heatmap"
            };
            _sensitivityMarkers.Add(new ChartMarker(currentFi, currentOutput, colors[comp], Tooltip: markerTooltip));
        }
    }

    // ── Eq (1) Radar: all 7 force components at a glance ──
    private void ComputeRadarAxes()
    {
        var forces = GetForces();
        var weights = GetWeights();
        var shortLabels = new[] { "Domain", "Arch.", "Taste", "Spec", "Debug", "Uncert.", "Motiv." };
        var fullLabels = new[] {
            "Domain Expertise", "Arch. Judgment", "Taste",
            "Spec Clarity", "Debug Intuition", "Calibrated Uncert.", "Intrinsic Motiv."
        };
        _radarAxes = new List<RadarAxis>();
        for (int i = 0; i < forces.Length; i++)
        {
            var pct = (forces[i] / 10.0 * 100).ToString("F0");
            var isAxis = i == _heatAxisX || i == _heatAxisY;
            var tooltip = new List<string>
            {
                $"{fullLabels[i]} (f{i + 1})",
                $"Value: {forces[i]:F1} / 10.0 ({pct}%)",
                $"Weight: {weights[i]:F2}",
                isAxis ? "Heatmap axis" : "Held fixed on heatmap"
            };
            _radarAxes.Add(new RadarAxis(shortLabels[i], forces[i], 10.0, tooltip));
        }
    }

    // ── Eq (1a) Layer bars: separate M_eff per layer ──
    private void ComputeLayerBars()
    {
        var surfaceOutput = _mEffSurface * _forceSurface;
        var middleOutput = _mEffMiddle * _forceMiddle;
        var deepOutput = _mEffDeep * _forceDeep;

        _layerBars = new List<BarItem>
        {
            new("Surface", surfaceOutput, "#f97316"),
            new("Middle", middleOutput, "#8b5cf6"),
            new("Deep", deepOutput, "#06b6d4")
        };

        _layerValid = _mEffSurface > _mEffMiddle
                   && _mEffMiddle > _mEffDeep
                   && Math.Abs(_mEffDeep - 1.0) < 1.0;
    }

    // ── Eq (2) Domain output contributions ──
    private void ComputeDomainBars()
    {
        var domainMs = new[] { _msBoilerplate, _msIntegration, _msArchitecture, _msDebugging };
        var domainFs = new[] { _fdBoilerplate, _fdIntegration, _fdArchitecture, _fdDebugging };
        var domainNames = new[] { "Boilerplate", "Integration", "Architecture", "Debugging" };
        var colors = new[] { "#2563eb", "#16a34a", "#9333ea", "#ea580c" };

        _domainTotal = BaseModel.ComputeOutputAcrossDomains(domainMs, domainFs);

        _domainStacks = new List<BarStack>();
        for (int i = 0; i < domainNames.Length; i++)
        {
            var contribution = domainMs[i] * domainFs[i];
            _domainStacks.Add(new BarStack(domainNames[i], new List<BarSegment>
            {
                new BarSegment($"Ms={domainMs[i]:F1}", contribution, colors[i])
            }));
        }
    }

    // ── Eq (3) Skill value sensitivity per domain ──
    private void ComputeSkillValueSeries()
    {
        const int pts = 50;
        var domainNames = new[] { "Boilerplate", "Integration", "Architecture", "Debugging" };
        var dMsRates = new[] { _dMsBoilerplate, _dMsIntegration, _dMsArchitecture, _dMsDebugging };
        var fBars = new[] { _fBarBoilerplate, _fBarIntegration, _fBarArchitecture, _fBarDebugging };
        var colors = new[] { "#2563eb", "#16a34a", "#9333ea", "#ea580c" };

        _skillValueSeries = new List<ChartSeries>();
        _skillReadouts = new Dictionary<string, double>();

        for (int d = 0; d < domainNames.Length; d++)
        {
            var points = new List<DataPoint>();
            for (int p = 0; p < pts; p++)
            {
                double ip = 0.1 + p * 9.9 / (pts - 1);
                // dMs/dIp diminishes with investment (logarithmic)
                double dMsAtIp = dMsRates[d] / (1.0 + 0.2 * ip);
                double dVs = BaseModel.SkillValueSensitivity(dMsAtIp, fBars[d]);
                points.Add(new DataPoint(ip, dVs));
            }
            _skillValueSeries.Add(new ChartSeries(domainNames[d], points, colors[d], 2.0, false));

            // Compute readout at current investment level
            double dMsCurrent = dMsRates[d] / (1.0 + 0.2 * _currentIp);
            _skillReadouts[domainNames[d]] = BaseModel.SkillValueSensitivity(dMsCurrent, fBars[d]);
        }
    }
}
