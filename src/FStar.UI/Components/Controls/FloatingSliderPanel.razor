@implements IAsyncDisposable
@inject IJSRuntime JS

@if (Visible && !_minimized)
{
    <div class="floating-slider-panel" id="@_elementId">
        <div class="floating-title-bar" id="@(_elementId)-titlebar">
            <span class="floating-title">@Title</span>
            <div class="floating-title-actions">
                <button class="floating-btn" @onclick="Minimize" aria-label="Minimize panel" title="Minimize">−</button>
            </div>
        </div>
        <div class="floating-slider-body">
            @ChildContent
        </div>
    </div>
}
else if (Visible && _minimized)
{
    <div class="floating-slider-pill" id="@_elementId"
         @onclick="Restore" title="Restore parameters">
        ⚙ @Title
    </div>
}

@code {
    private readonly string _elementId = $"floating-{Guid.NewGuid():N}";
    private bool _minimized;
    private bool _jsInitialized;
    private IJSObjectReference? _module;

    [Parameter] public bool Visible { get; set; } = true;
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public bool StartMinimized { get; set; } = true;
    [Parameter] public string Title { get; set; } = "Parameters";
    [Parameter] public int DefaultX { get; set; } = -1;
    [Parameter] public int DefaultY { get; set; } = 80;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized() => _minimized = StartMinimized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_minimized && !_jsInitialized)
        {
            try
            {
                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/FStar.UI/FStar.UI.lib.module.js");
                await _module.InvokeVoidAsync("initDraggable", _elementId, $"{_elementId}-titlebar", DefaultX, DefaultY);
                _jsInitialized = true;
            }
            catch (JSException) { /* SSR / prerender guard */ }
        }
    }

    private void Minimize() => _minimized = true;

    private void Restore()
    {
        _minimized = false;
        _jsInitialized = false; // re-init drag on next render
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("destroyDraggable", _elementId);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}
